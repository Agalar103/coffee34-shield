    <script>
        // Tab switching logic
        function toggleTab(tab) {
            const simTab = document.getElementById('tab-simulator');
            const cfgTab = document.getElementById('tab-configs');
            const btnSim = document.getElementById('btn-tab-sim');
            const btnCfg = document.getElementById('btn-tab-cfg');

            if (tab === 'simulator') {
                simTab.classList.remove('hidden');
                cfgTab.classList.add('hidden');
                btnSim.className = "px-3 py-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-semibold transition";
                btnCfg.className = "px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 font-semibold transition";
            } else {
                simTab.classList.add('hidden');
                cfgTab.classList.remove('hidden');
                btnCfg.className = "px-3 py-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-semibold transition";
                btnSim.className = "px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 font-semibold transition";
            }
        }

        // Shield Configuration State
        const shieldConfig = {
            maxRps: 50,
            windowMs: 500,
            banDurationSec: 10,
            powChallengeEnabled: true
        };

        function updateLimit(type, val) {
            if (type === 'rps') {
                shieldConfig.maxRps = parseInt(val);
                document.getElementById('val-rps').innerText = `${val} req/s`;
            } else if (type === 'window') {
                shieldConfig.windowMs = parseInt(val);
                document.getElementById('val-window').innerText = `${val} ms`;
            } else if (type === 'ban') {
                shieldConfig.banDurationSec = parseInt(val);
                document.getElementById('val-ban').innerText = `${val} sn`;
            }
        }

        // Live Traffic Analytics State
        const activeIps = new Map(); // IP -> { history: [], bannedUntil: timestamp, isBot: bool }
        let stats = { passed: 0, limited: 0, banned: 0 };

        // Chart Initialization
        const ctx = document.getElementById('trafficChart').getContext('2d');
        const maxDataPoints = 30;
        const chartData = {
            labels: Array(maxDataPoints).fill(''),
            datasets: [
                {
                    label: 'Başarılı (200)',
                    data: Array(maxDataPoints).fill(0),
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    fill: true,
                    tension: 0.4
                },
                {
                    label: 'Limitledi (429)',
                    data: Array(maxDataPoints).fill(0),
                    borderColor: '#f59e0b',
                    backgroundColor: 'transparent',
                    tension: 0.4
                },
                {
                    label: 'Engellendi (403)',
                    data: Array(maxDataPoints).fill(0),
                    borderColor: '#ef4444',
                    backgroundColor: 'transparent',
                    tension: 0.4
                }
            ]
        };

        const trafficChart = new Chart(ctx, {
            type: 'line',
            data: chartData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: false,
                scales: {
                    x: { display: false },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(255, 255, 255, 0.05)' },
                        ticks: { color: '#9ca3af' }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // Traffic Generator Loop
        let simulationTimer = null;
        let currentMode = 'stop';

        function triggerTraffic(mode) {
            currentMode = mode;
            if (simulationTimer) clearInterval(simulationTimer);

            const interval = mode === 'normal' ? 200 : mode === 'burst' ? 50 : 15;
            simulationTimer = setInterval(() => {
                simulateIncomingRequest();
            }, interval);

            document.getElementById('statusText').innerText = mode === 'ddos' 
                ? 'SALDIRI ALTINDA - Kalkan Filtreliyor' 
                : 'Kalkan Aktif (Katman 7)';
        }

        function stopTraffic() {
            currentMode = 'stop';
            if (simulationTimer) clearInterval(simulationTimer);
            document.getElementById('statusText').innerText = 'Kalkan Beklemede';
        }

        function simulateIncomingRequest() {
            const now = Date.now();
            let ip;
            let isAttacker = false;

            if (currentMode === 'normal') {
                ip = `192.168.1.${Math.floor(Math.random() * 20) + 1}`;
            } else if (currentMode === 'burst') {
                ip = `10.0.0.${Math.floor(Math.random() * 50) + 1}`;
            } else { // ddos
                isAttacker = Math.random() > 0.15;
                if (isAttacker) {
                    // Botnet Cluster IPs
                    const botnetCluster = [
                        '45.142.120.12', '185.220.101.5', '91.240.118.88', 
                        '193.27.228.10', '103.14.26.190'
                    ];
                    ip = botnetCluster[Math.floor(Math.random() * botnetCluster.length)];
                } else {
                    ip = `192.168.1.${Math.floor(Math.random() * 5) + 1}`;
                }
            }

            // Inspect request through shield logic
            let clientData = activeIps.get(ip) || { history: [], bannedUntil: 0 };
            
            // Check if banned
            if (clientData.bannedUntil > now) {
                stats.banned++;
                logRequest(ip, '/api/data', 403, 'ENGEL SÜRESİ AKTİF', 'IP Yasaklı Tablosunda');
                updateChartStats(0, 0, 1);
                return;
            }

            // Filter history for sliding window
            clientData.history = clientData.history.filter(timestamp => timestamp > (now - shieldConfig.windowMs));
            clientData.history.push(now);
            activeIps.set(ip, clientData);

            document.getElementById('stat-ips').innerText = activeIps.size;

            // Rate Limit Evaluation
            if (clientData.history.length > shieldConfig.maxRps) {
                // Exceeded limit
                if (clientData.history.length > shieldConfig.maxRps * 2.5) {
                    // Auto Ban Trigger
                    clientData.bannedUntil = now + (shieldConfig.banDurationSec * 1000);
                    stats.banned++;
                    logRequest(ip, '/api/data', 403, 'OTOMATİK BANLANDI', `Sınır ${clientData.history.length} req ile aşıldı!`);
                    updateChartStats(0, 0, 1);
                } else {
                    stats.limited++;
                    logRequest(ip, '/api/data', 429, 'ORAN SINIRI AŞILDI', '429 Too Many Requests');
                    updateChartStats(0, 1, 0);
                }
            } else {
                stats.passed++;
                logRequest(ip, '/api/data', 200, 'İZİN VERİLDİ', 'Kalkan Temiz Geçiş Onayı Verdi');
                updateChartStats(1, 0, 0);
            }
        }

        // Live Metrics Buffer for Chart
        let pendingChartUpdate = { passed: 0, limited: 0, banned: 0 };

        function updateChartStats(passed, limited, banned) {
            pendingChartUpdate.passed += passed;
            pendingChartUpdate.limited += limited;
            pendingChartUpdate.banned += banned;

            document.getElementById('stat-passed').innerText = stats.passed;
            document.getElementById('stat-limited').innerText = stats.limited;
            document.getElementById('stat-banned').innerText = stats.banned;
        }

        // Chart Refresh Timer (every 1 sec)
        setInterval(() => {
            chartData.datasets[0].data.shift();
            chartData.datasets[0].data.push(pendingChartUpdate.passed);

            chartData.datasets[1].data.shift();
            chartData.datasets[1].data.push(pendingChartUpdate.limited);

            chartData.datasets[2].data.shift();
            chartData.datasets[2].data.push(pendingChartUpdate.banned);

            trafficChart.update();

            // Reset pending counts
            pendingChartUpdate = { passed: 0, limited: 0, banned: 0 };
        }, 1000);

        // Logging UI Update
        function logRequest(ip, path, status, action, reason) {
            const tbody = document.getElementById('logTableBody');
            const tr = document.createElement('tr');
            
            let statusBadge = '';
            if (status === 200) statusBadge = '<span class="text-emerald-400 font-bold">200 OK</span>';
            else if (status === 429) statusBadge = '<span class="text-amber-400 font-bold">429 LIMIT</span>';
            else statusBadge = '<span class="text-red-400 font-bold">403 BAN</span>';

            const timeStr = new Date().toLocaleTimeString();

            tr.innerHTML = `
                <td class="py-1.5 px-3 text-gray-500">${timeStr}</td>
                <td class="py-1.5 px-3 text-gray-200 font-bold">${ip}</td>
                <td class="py-1.5 px-3 text-gray-400">${path}</td>
                <td class="py-1.5 px-3">${statusBadge}</td>
                <td class="py-1.5 px-3 text-gray-300">${action}</td>
                <td class="py-1.5 px-3 text-gray-500 text-[10px]">${reason}</td>
            `;

            tbody.insertBefore(tr, tbody.firstChild);

            // Keep table truncated to 20 rows max for smooth UI
            if (tbody.children.length > 20) {
                tbody.removeChild(tbody.lastChild);
            }
        }

        function clearLogs() {
            document.getElementById('logTableBody').innerHTML = '';
            stats = { passed: 0, limited: 0, banned: 0 };
            document.getElementById('stat-passed').innerText = '0';
            document.getElementById('stat-limited').innerText = '0';
            document.getElementById('stat-banned').innerText = '0';
        }

        function copyCode(elementId) {
            const text = document.getElementById(elementId).innerText;
            const textArea = document.createElement('textarea');
            textArea.value = text;
            document.body.appendChild(textArea);
            textArea.select();
            document.execCommand('copy');
            document.body.removeChild(textArea);
            alert('Kod panoya kopyalandı!');
        }
    </script>
</body>
</html>
