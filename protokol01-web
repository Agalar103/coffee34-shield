                <!-- Nginx Config -->
                <div class="glass-panel rounded-xl p-6 border border-gray-800 space-y-3">
                    <div class="flex justify-between items-center">
                        <div class="flex items-center gap-2">
                            <i class="fa-brands fa-linux text-emerald-400 text-lg"></i>
                            <h3 class="text-sm font-bold text-white">1. Nginx L7 DDoS & Rate Limiting Yapılandırması (`/etc/nginx/nginx.conf`)</h3>
                        </div>
                        <button onclick="copyCode('code-nginx')" class="text-xs bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-1.5 rounded transition">
                            <i class="fa-regular fa-copy mr-1"></i>Kopyala
                        </button>
                    </div>
                    <pre class="bg-gray-900 p-4 rounded-lg text-xs font-mono text-emerald-300 overflow-x-auto border border-gray-800" id="code-nginx"><code># Nginx Http Blok İçerisine Ekleyin
http {
    # IP başına saniyede maksimum 10 istek, 10MB hafıza alanı
    limit_req_zone $binary_remote_addr zone=ddos_limit:10m rate=10r/s;
    limit_conn_zone $binary_remote_addr zone=addr_limit:10m;

    server {
        listen 80;
        server_name example.com;

        # Ani patlamalara (burst) 20 isteğe kadar izin ver, gerisini nodelay ile reddet
        limit_req zone=ddos_limit burst=20 nodelay;
        limit_conn addr_limit 10; # Aynı IP'den maks 10 eşzamanlı bağlantı

        # Anormal yavaş bağlantı / Slowloris koruması
        client_body_timeout 10s;
        client_header_timeout 10s;
        keepalive_timeout 15s;
        send_timeout 10s;

        location / {
            proxy_pass http://backend_cluster;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header Host $host;
        }
    }
}</code></pre>
                </div>

                <!-- Node.js / Express Middleware -->
                <div class="glass-panel rounded-xl p-6 border border-gray-800 space-y-3">
