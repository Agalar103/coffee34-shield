                            <i class="fa-brands fa-node-js text-emerald-400 text-lg"></i>
                            <h3 class="text-sm font-bold text-white">2. Node.js Express.js Sliding Window Rate Limiter Kalkanı</h3>
                        </div>
                        <button onclick="copyCode('code-node')" class="text-xs bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-1.5 rounded transition">
                            <i class="fa-regular fa-copy mr-1"></i>Kopyala
                        </button>
                    </div>
                    <pre class="bg-gray-900 p-4 rounded-lg text-xs font-mono text-emerald-300 overflow-x-auto border border-gray-800" id="code-node"><code>const express = require('express');
const rateLimit = require('express-rate-limit');
const app = express();

// Katman 7 DDoS Koruma Filtresi
const ddosLimiter = rateLimit({
    windowMs: 1 * 60 * 1000, // 1 Dakikalık Pencere
    max: 100, // IP başına 1 dakikada maks 100 istek
    standardHeaders: true, // Return rate limit info in the `RateLimit-*` headers
    legacyHeaders: false,
    message: {
        status: 429,
        error: "Çok fazla istek gönderildi. Lütfen bir süre sonra tekrar deneyin.",
        shield: "Active DDoS Mitigation"
    },
    handler: (req, res, next, options) => {
        console.warn(`[DDOS SHIELD] Limit aşıldı! Engellenen IP: ${req.ip}`);
        res.status(options.statusCode).send(options.message);
    }
});

// Tüm rotalara korumayı uygula
app.use(ddosLimiter);

app.get('/', (req, res) => {
    res.send("Güvenli sunucuya erişim sağlandı!");
});

app.listen(3000, () => console.log("DDoS Kalkanlı Sunucu 3000 Portunda Aktif!"));</code></pre>
